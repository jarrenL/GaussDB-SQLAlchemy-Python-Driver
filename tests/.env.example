# GaussDB connection parameters for tests
# Copy to .env or export these before running tests
# If GAUSSDB_HOST is not set, integration tests will be skipped automatically.

# Required
GAUSSDB_HOST=121.37.186.131
GAUSSDB_PORT=19995
GAUSSDB_USER=sqlbuilder1
GAUSSDB_PASSWORD=huawei@123

# ODBC driver name (registered in Windows ODBC Data Source Administrator)
# Common values: "GaussDB ODBC Driver", "GaussDB Unicode", "PostgreSQL"
GAUSSDB_DRIVER=GaussDB ODBC Driver

# Database names for each compatibility mode
GAUSSDB_DB_A=postgres
GAUSSDB_DB_B=gdbdrv_b_compat
GAUSSDB_DB_M=testm

# Optional: override the full test URL (bypasses all above for integration_env tests)
# GAUSSDB_TEST_URL=gaussdb+odbc://user:pass@host:port/db?driver=GaussDB+ODBC+Driver&sslmode=disable
